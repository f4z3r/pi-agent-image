{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", "group:allNonMajor"],
  "customManagers": [
    {
      "description": "Update npm packages within the dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": ["(?<depName>@\\S+)@(?<currentValue>\\S+)"],
      "datasourceTemplate": "npm"
    }
  ]
}
